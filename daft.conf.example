# daft configuration (key = value). All keys optional.

# Raw MIDI byte sink: a rawmidi device, OSS-emulation device, or FIFO.
midi_path = /dev/midi

# PRNG seed (decimal). Identical seed + identical metrics => identical music.
seed = 240106

# Pitch class of the tonal root: 0=C 1=C# 2=D ... 5=F ... 11=B
root = 5

# bright = Music for Airports dawn; dark = Discreet Music dusk
mood = bright

# Overall event-density scale, percent (25..400).
density_percent = 100
